<%- include('../partials/head', { pageTitle: editing ? 'Edit Vitals' : 'Record Vitals' }) %>

<section class="admin-editor">
  <a href="/admin" class="back-link">&larr; Back to dashboard</a>

  <h1><%= editing ? 'Edit Vitals' : 'Record Vitals' %></h1>

  <% const prev = editing || latest || {}; %>
  <form method="POST" action="<%= editing ? '/admin/vitals/edit/' + editing.id : '/admin/vitals' %>" class="editor-form">
    <div class="form-row">
      <div class="form-group">
        <label for="recorded_at">Date & Time</label>
        <input type="datetime-local" id="recorded_at" name="recorded_at" value="<%= editing && editing.recorded_at ? editing.recorded_at.slice(0, 16) : new Date().toISOString().slice(0, 16) %>">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="weight_grams">Weight (grams)</label>
        <input type="number" id="weight_grams" name="weight_grams" step="1" placeholder="e.g. 680" value="<%= prev.weight_grams || '' %>">
      </div>
      <div class="form-group">
        <label for="length_cm">Length (cm)</label>
        <input type="number" id="length_cm" name="length_cm" step="0.1" placeholder="e.g. 30.5" value="<%= prev.length_cm || '' %>">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="head_circumference_cm">Head Circumference (cm)</label>
        <input type="number" id="head_circumference_cm" name="head_circumference_cm" step="0.1" placeholder="e.g. 22" value="<%= prev.head_circumference_cm || '' %>">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="temperature">Temperature (&deg;F)</label>
        <input type="number" id="temperature" name="temperature" step="0.1" placeholder="e.g. 98.6" value="<%= prev.temperature || '' %>">
      </div>
      <div class="form-group">
        <label for="heart_rate">Heart Rate (bpm)</label>
        <input type="number" id="heart_rate" name="heart_rate" step="1" placeholder="e.g. 150" value="<%= prev.heart_rate || '' %>">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="respiratory_rate">Respirations (breaths/min)</label>
        <input type="number" id="respiratory_rate" name="respiratory_rate" step="1" placeholder="e.g. 40" value="<%= prev.respiratory_rate || '' %>">
      </div>
      <div class="form-group">
        <label for="blood_pressure">Blood Pressure</label>
        <input type="text" id="blood_pressure" name="blood_pressure" placeholder="e.g. 60/35" value="<%= prev.blood_pressure || '' %>">
      </div>
      <div class="form-group">
        <label for="oxygen_saturation">SpO2 (%)</label>
        <input type="number" id="oxygen_saturation" name="oxygen_saturation" step="1" min="0" max="100" placeholder="e.g. 95" value="<%= prev.oxygen_saturation || '' %>">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="respiratory_support">Respiratory Support</label>
        <select id="respiratory_support" name="respiratory_support">
          <option value="">-- Select --</option>
          <% ['High-frequency ventilator', 'Conventional ventilator', 'CPAP', 'Nasal cannula', 'Room air'].forEach(opt => { %>
          <option value="<%= opt %>" <%= prev.respiratory_support === opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label for="fio2">FiO2 (%)</label>
        <input type="number" id="fio2" name="fio2" step="1" min="21" max="100" placeholder="e.g. 30" value="<%= prev.fio2 || '' %>">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="crib_type">Crib Type</label>
        <select id="crib_type" name="crib_type">
          <option value="">-- Select --</option>
          <% ['Isolette (closed)', 'Isolette (open top)', 'Open crib', 'Bassinet'].forEach(opt => { %>
          <option value="<%= opt %>" <%= prev.crib_type === opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="feeding_type">Feeding Type</label>
        <select id="feeding_type" name="feeding_type">
          <option value="">-- Select --</option>
          <% ['TPN (IV nutrition)', 'Trophic feeds', 'Gavage (tube)', 'Breast', 'Bottle', 'Breast + bottle'].forEach(opt => { %>
          <option value="<%= opt %>" <%= prev.feeding_type === opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label for="feeding_volume_ml">Feeding Volume (ml)</label>
        <input type="number" id="feeding_volume_ml" name="feeding_volume_ml" step="0.1" placeholder="e.g. 12" value="<%= prev.feeding_volume_ml || '' %>">
      </div>
      <div class="form-group">
        <label for="feeding_frequency_minutes">Feeding Every (minutes)</label>
        <input type="number" id="feeding_frequency_minutes" name="feeding_frequency_minutes" step="1" placeholder="e.g. 180" value="<%= prev.feeding_frequency_minutes || '' %>">
      </div>
    </div>

    <div class="form-group">
      <label for="notes">Notes</label>
      <textarea id="notes" name="notes" rows="3" placeholder="Any observations, changes, or concerns..."><%= prev.notes || '' %></textarea>
    </div>

    <button type="submit" class="btn btn-primary btn-full"><%= editing ? 'Save Changes' : 'Save Vitals' %></button>
  </form>

  <% if (vitals.length > 0) { %>
  <h2 style="margin: 2rem 0 1rem;">Recent Entries</h2>
  <div class="admin-list">
    <% vitals.forEach(v => { %>
    <div class="admin-item">
      <div class="admin-item-info">
        <div class="admin-item-top">
          <time><%= new Date(v.recorded_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %></time>
        </div>
        <p>
          <% if (v.weight_grams) { %>Wt: <%= v.weight_grams %>g &nbsp;<% } %>
          <% if (v.length_cm) { %>L: <%= v.length_cm %>cm &nbsp;<% } %>
          <% if (v.head_circumference_cm) { %>HC: <%= v.head_circumference_cm %>cm &nbsp;<% } %>
          <% if (v.temperature) { %>T: <%= v.temperature %>&deg;F &nbsp;<% } %>
          <% if (v.heart_rate) { %>HR: <%= v.heart_rate %> &nbsp;<% } %>
          <% if (v.respiratory_rate) { %>RR: <%= v.respiratory_rate %> &nbsp;<% } %>
          <% if (v.blood_pressure) { %>BP: <%= v.blood_pressure %> &nbsp;<% } %>
          <% if (v.oxygen_saturation) { %>SpO2: <%= v.oxygen_saturation %>% &nbsp;<% } %>
          <% if (v.respiratory_support) { %><%= v.respiratory_support %> &nbsp;<% } %>
          <% if (v.fio2) { %>FiO2: <%= v.fio2 %>% &nbsp;<% } %>
          <% if (v.feeding_frequency_minutes) { %>q<%= v.feeding_frequency_minutes >= 60 ? (v.feeding_frequency_minutes / 60) + 'h' : v.feeding_frequency_minutes + 'min' %> &nbsp;<% } %>
          <% if (v.crib_type) { %><%= v.crib_type %><% } %>
        </p>
      </div>
      <div class="admin-item-actions">
        <a href="/admin/vitals/edit/<%= v.id %>" class="btn btn-small">Edit</a>
        <form method="POST" action="/admin/vitals/delete/<%= v.id %>" style="display:inline" onsubmit="return confirm('Delete this entry?')">
          <button type="submit" class="btn btn-small btn-danger">Delete</button>
        </form>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
