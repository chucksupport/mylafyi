<%- include('../partials/head', { pageTitle: 'Record Vitals' }) %>

<section class="admin-editor">
  <a href="/admin" class="back-link">&larr; Back to dashboard</a>

  <h1>Record Vitals</h1>

  <form method="POST" action="/admin/vitals" class="editor-form">
    <div class="form-row">
      <div class="form-group">
        <label for="recorded_at">Date & Time</label>
        <input type="datetime-local" id="recorded_at" name="recorded_at" value="<%= new Date().toISOString().slice(0, 16) %>">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="weight_grams">Weight (grams)</label>
        <input type="number" id="weight_grams" name="weight_grams" step="1" placeholder="e.g. 680">
      </div>
      <div class="form-group">
        <label for="heart_rate">Heart Rate (bpm)</label>
        <input type="number" id="heart_rate" name="heart_rate" placeholder="e.g. 145">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="oxygen_saturation">Oxygen Sat (%)</label>
        <input type="number" id="oxygen_saturation" name="oxygen_saturation" step="0.1" placeholder="e.g. 94">
      </div>
      <div class="form-group">
        <label for="temperature">Temperature (&deg;F)</label>
        <input type="number" id="temperature" name="temperature" step="0.1" placeholder="e.g. 98.6">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="respiratory_support">Respiratory Support</label>
        <select id="respiratory_support" name="respiratory_support">
          <option value="">-- Select --</option>
          <option value="High-frequency ventilator">High-frequency ventilator</option>
          <option value="Conventional ventilator">Conventional ventilator</option>
          <option value="CPAP">CPAP</option>
          <option value="Nasal cannula">Nasal cannula</option>
          <option value="Room air">Room air</option>
        </select>
      </div>
      <div class="form-group">
        <label for="fio2">FiO2 (%)</label>
        <input type="number" id="fio2" name="fio2" step="1" min="21" max="100" placeholder="21-100">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="feeding_type">Feeding Type</label>
        <select id="feeding_type" name="feeding_type">
          <option value="">-- Select --</option>
          <option value="TPN (IV nutrition)">TPN (IV nutrition)</option>
          <option value="Trophic feeds">Trophic feeds</option>
          <option value="Gavage (tube)">Gavage (tube)</option>
          <option value="Breast">Breast</option>
          <option value="Bottle">Bottle</option>
          <option value="Breast + bottle">Breast + bottle</option>
        </select>
      </div>
      <div class="form-group">
        <label for="feeding_volume_ml">Feeding Volume (ml)</label>
        <input type="number" id="feeding_volume_ml" name="feeding_volume_ml" step="0.1" placeholder="e.g. 12">
      </div>
    </div>

    <div class="form-group">
      <label for="notes">Notes</label>
      <textarea id="notes" name="notes" rows="3" placeholder="Any observations, changes, or concerns..."></textarea>
    </div>

    <button type="submit" class="btn btn-primary btn-full">Save Vitals</button>
  </form>

  <% if (vitals.length > 0) { %>
  <h2 style="margin: 2rem 0 1rem;">Recent Entries</h2>
  <div class="admin-list">
    <% vitals.forEach(v => { %>
    <div class="admin-item">
      <div class="admin-item-info">
        <div class="admin-item-top">
          <time><%= new Date(v.recorded_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %></time>
        </div>
        <p>
          <% if (v.weight_grams) { %>Wt: <%= v.weight_grams %>g &nbsp;<% } %>
          <% if (v.heart_rate) { %>HR: <%= v.heart_rate %> &nbsp;<% } %>
          <% if (v.oxygen_saturation) { %>SpO2: <%= v.oxygen_saturation %>% &nbsp;<% } %>
          <% if (v.temperature) { %>T: <%= v.temperature %>&deg;F &nbsp;<% } %>
          <% if (v.respiratory_support) { %><%= v.respiratory_support %><% } %>
        </p>
      </div>
      <div class="admin-item-actions">
        <form method="POST" action="/admin/vitals/delete/<%= v.id %>" style="display:inline" onsubmit="return confirm('Delete this entry?')">
          <button type="submit" class="btn btn-small btn-danger">Delete</button>
        </form>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
