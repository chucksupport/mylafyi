<%- include('../partials/head', { pageTitle: update ? 'Edit Update' : 'New Update' }) %>

<section class="admin-editor">
  <a href="/admin" class="back-link">Back to dashboard</a>

  <h1><%= update ? 'Edit Update' : 'New Update' %></h1>

  <form method="POST" action="<%= update ? '/admin/edit/' + update.id : '/admin/new' %>" enctype="multipart/form-data" class="editor-form">
    <div class="form-group">
      <label for="title">Title</label>
      <input type="text" id="title" name="title" value="<%= update ? update.title : '' %>" required placeholder="e.g. Day 12 - Getting Stronger">
    </div>

    <div class="form-group">
      <label for="update_date">Date & Time</label>
      <input type="datetime-local" id="update_date" name="update_date" value="<%= update && update.update_date ? update.update_date.slice(0, 16) : new Date().toISOString().slice(0, 16) %>" required>
    </div>

    <div class="form-group">
      <label for="sentiment">How's she doing? <span id="sentiment-label" style="font-weight:400; color: var(--gray-400);"></span></label>
      <input type="range" id="sentiment" name="sentiment" min="1" max="10" value="<%= update ? update.sentiment || 5 : 5 %>" style="width:100%; accent-color: var(--rose-500);">
      <div style="display:flex; justify-content:space-between; font-size:0.75rem; color:var(--gray-400); margin-top:0.25rem;">
        <span>Rough day</span>
        <span>Amazing day</span>
      </div>
    </div>

    <div class="form-group">
      <label for="content">What happened today?</label>
      <textarea id="content" name="content" rows="10" required placeholder="Tell everyone how Myla is doing today..."><%= update ? update.content : '' %></textarea>
    </div>

    <div class="form-group">
      <label for="photo">Photo (optional)</label>
      <input type="file" id="photo" name="photo" accept="image/*">
      <% if (update && update.photo) { %>
        <div class="current-photo">
          <p>Current photo:</p>
          <img src="<%= update.photo %>" alt="Current photo" style="max-width: 200px; border-radius: 8px;">
        </div>
      <% } %>
    </div>

    <button type="submit" class="btn btn-primary btn-full"><%= update ? 'Save Changes' : 'Post Update' %></button>
  </form>
</section>

<script>
(function() {
  const slider = document.getElementById('sentiment');
  const label = document.getElementById('sentiment-label');
  const labels = ['','Very rough','Rough','Hard','Below average','Okay','Decent','Good','Great','Wonderful','Amazing'];
  function update() { label.textContent = '(' + labels[parseInt(slider.value)] + ')'; }
  slider.addEventListener('input', update);
  update();
})();
</script>
<%- include('../partials/footer') %>
