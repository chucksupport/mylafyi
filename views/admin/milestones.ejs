<%- include('../partials/head', { pageTitle: 'Milestones' }) %>

<section class="admin-editor">
  <a href="/admin" class="back-link">&larr; Back to dashboard</a>

  <h1>Manage Milestones</h1>

  <% const categoryLabels = { breathing: 'Respiratory', feeding: 'Gastrointestinal', growth: 'Skeletal Growth', thermoregulation: 'Thermoregulation', firsts: 'Neurological', iv_and_lines: 'IV & Lines' };
     function formatCategory(cat) { return categoryLabels[cat] || cat.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()); } %>

  <% Object.keys(milestones).forEach(cat => { %>
  <div class="milestone-admin-section">
    <h2><%= formatCategory(cat) %></h2>
    <div class="admin-list">
      <% milestones[cat].forEach(m => { %>
      <div class="admin-item milestone-admin-item <%= m.achieved ? 'milestone-achieved' : '' %>">
        <div class="admin-item-info">
          <h3><% if (m.achieved) { %>&#10003; <% } %><%= m.title %></h3>
          <% if (m.description) { %><p><%= m.description %></p><% } %>
          <% if (m.achieved && m.achieved_at) { %>
          <time class="milestone-date">Achieved: <%= new Date(m.achieved_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></time>
          <% } %>
        </div>
        <div class="admin-item-actions">
          <% if (m.achieved) { %>
          <form method="POST" action="/admin/milestones/unachieve/<%= m.id %>" style="display:inline">
            <button type="submit" class="btn btn-small btn-outline">Undo</button>
          </form>
          <% } else { %>
          <form method="POST" action="/admin/milestones/achieve/<%= m.id %>" style="display:inline; display:flex; align-items:center; gap:0.5rem;">
            <input type="date" name="achieved_date" value="<%= new Date().toISOString().slice(0, 10) %>" style="padding:0.25rem 0.5rem; border-radius:6px; border:1px solid var(--gray-600); background:var(--gray-800); color:var(--gray-100); font-size:0.8rem;">
            <button type="submit" class="btn btn-small btn-primary">Achieved!</button>
          </form>
          <% } %>
          <form method="POST" action="/admin/milestones/delete/<%= m.id %>" style="display:inline" onsubmit="return confirm('Delete this milestone?')">
            <button type="submit" class="btn btn-small btn-danger">Delete</button>
          </form>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
  <% }) %>

  <div class="milestone-admin-section">
    <h2>Add Custom Milestone</h2>
    <form method="POST" action="/admin/milestones/new" class="editor-form">
      <div class="form-row">
        <div class="form-group">
          <label for="category">Category</label>
          <select id="category" name="category" required>
            <option value="firsts">Neurological</option>
            <option value="breathing">Respiratory</option>
            <option value="feeding">Gastrointestinal</option>
            <option value="thermoregulation">Thermoregulation</option>
            <option value="growth">Skeletal Growth</option>
            <option value="iv_and_lines">IV & Lines</option>
          </select>
        </div>
        <div class="form-group">
          <label for="title">Title</label>
          <input type="text" id="title" name="title" required placeholder="e.g. First smile">
        </div>
      </div>
      <div class="form-group">
        <label for="description">Description (optional)</label>
        <input type="text" id="description" name="description" placeholder="Brief description">
      </div>
      <button type="submit" class="btn btn-primary">Add Milestone</button>
    </form>
  </div>
</section>

<%- include('../partials/footer') %>
