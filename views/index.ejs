<%- include('partials/head') %>

<section class="hero">
  <div class="hero-inner">
    <p class="hero-label">Born at <%= settings.gestational_age_weeks %> weeks and <%= settings.gestational_age_days %> days</p>
    <h1>Myla Liane Grigsby</h1>
    <% const bd = new Date(settings.birth_date + 'T' + (settings.birth_time || '00:00') + ':00'); %>
    <p class="subtitle">Born <%= bd.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %> at <%= bd.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) %></p>

    <div class="stat-cards">
      <div class="stat-card">
        <span class="stat-number"><%= ageInfo.nicuDays %></span>
        <span class="stat-label">Days Old</span>
      </div>
      <div class="stat-card">
        <span class="stat-number"><%= ageInfo.correctedGestWeeks %>+<%= ageInfo.correctedGestRemainder %></span>
        <span class="stat-label">Corrected Gestational Age (wks)</span>
      </div>
      <% if (ageInfo.daysToDueDate > 0) { %>
      <div class="stat-card">
        <span class="stat-number"><%= ageInfo.daysToDueDate %></span>
        <span class="stat-label">Days to Due Date</span>
      </div>
      <% } else { %>
      <div class="stat-card">
        <span class="stat-number"><%= ageInfo.correctedWeeks %>w<%= ageInfo.correctedRemainder %>d</span>
        <span class="stat-label">Corrected Age</span>
      </div>
      <% } %>
    </div>
  </div>
</section>

<% if (latestVitals) { %>
<section class="section vitals-snapshot">
  <div class="section-header">
    <h2>Latest Vitals</h2>
    <a href="/vitals" class="section-link">View all vitals</a>
  </div>
  <div class="vitals-grid">
    <% if (latestVitals.weight_grams) { %>
    <div class="vital-card">
      <div class="vital-icon-emoji">&#x2696;&#xFE0F;</div>
      <div class="vital-info">
        <span class="vital-value"><%= latestVitals.weight_grams %><small>g</small></span>
        <span class="vital-label">Weight</span>
      </div>
    </div>
    <% } %>
    <% if (latestVitals.length_cm) { %>
    <div class="vital-card">
      <div class="vital-icon-emoji">&#x1F4CF;</div>
      <div class="vital-info">
        <span class="vital-value"><%= latestVitals.length_cm %><small>cm</small></span>
        <span class="vital-label">Length</span>
      </div>
    </div>
    <% } %>
    <% if (latestVitals.head_circumference_cm) { %>
    <div class="vital-card">
      <div class="vital-icon-emoji">&#x1F476;</div>
      <div class="vital-info">
        <span class="vital-value"><%= latestVitals.head_circumference_cm %><small>cm</small></span>
        <span class="vital-label">Head Circ.</span>
      </div>
    </div>
    <% } %>
    <% if (latestVitals.heart_rate) { %>
    <div class="vital-card">
      <div class="vital-icon-emoji">&#x1F493;</div>
      <div class="vital-info">
        <span class="vital-value"><%= latestVitals.heart_rate %><small>bpm</small></span>
        <span class="vital-label">Heart Rate</span>
      </div>
    </div>
    <% } %>
    <% if (latestVitals.oxygen_saturation) { %>
    <div class="vital-card">
      <div class="vital-icon-emoji">&#x1FAC1;</div>
      <div class="vital-info">
        <span class="vital-value"><%= latestVitals.oxygen_saturation %><small>%</small></span>
        <span class="vital-label">Oxygen Sat</span>
      </div>
    </div>
    <% } %>
    <% if (latestVitals.temperature) { %>
    <div class="vital-card">
      <div class="vital-icon-emoji">&#x1F321;&#xFE0F;</div>
      <div class="vital-info">
        <span class="vital-value"><%= latestVitals.temperature %><small>&deg;F</small></span>
        <span class="vital-label">Temperature</span>
      </div>
    </div>
    <% } %>
    <% if (latestVitals.respiratory_support) { %>
    <div class="vital-card">
      <div class="vital-icon-emoji">&#x1FAC1;</div>
      <div class="vital-info">
        <span class="vital-value text"><%= latestVitals.respiratory_support %></span>
        <span class="vital-label">Respiratory Support</span>
      </div>
    </div>
    <% } %>
    <% if (latestVitals.crib_type) { %>
    <div class="vital-card">
      <div class="vital-icon-emoji">&#x1F6CF;&#xFE0F;</div>
      <div class="vital-info">
        <span class="vital-value text"><%= latestVitals.crib_type %></span>
        <span class="vital-label">Crib Type</span>
      </div>
    </div>
    <% } %>
    <% if (latestVitals.feeding_type || latestVitals.feeding_volume_ml || latestVitals.feeding_frequency_minutes) { %>
    <div class="vital-card">
      <div class="vital-icon-emoji">&#x1F37C;</div>
      <div class="vital-info">
        <span class="vital-value text"><%= latestVitals.feeding_volume_ml ? latestVitals.feeding_volume_ml + 'ml' : '' %><%= latestVitals.feeding_volume_ml && latestVitals.feeding_frequency_minutes ? ' / ' : '' %><%= latestVitals.feeding_frequency_minutes ? (latestVitals.feeding_frequency_minutes >= 60 ? (latestVitals.feeding_frequency_minutes / 60) + 'h' : latestVitals.feeding_frequency_minutes + 'min') : '' %></span>
        <span class="vital-label"><%= latestVitals.feeding_type || 'Feeding' %></span>
      </div>
    </div>
    <% } %>
  </div>

  <% if (vitals.length >= 3) { %>
  <div class="chart-container">
    <canvas id="weightChart" height="200"></canvas>
  </div>
  <% } %>
</section>
<% } %>

<% const achievedMilestones = []; const allMilestones = []; Object.values(milestones).forEach(arr => arr.forEach(m => { allMilestones.push(m); if (m.achieved) achievedMilestones.push(m); })); %>
<% if (allMilestones.length > 0) { %>
<section class="section milestones-snapshot">
  <div class="section-header">
    <h2>Milestones</h2>
    <a href="/milestones" class="section-link">View all</a>
  </div>
  <div class="milestone-progress-bar">
    <div class="milestone-progress-fill" style="width: <%= Math.round((achievedMilestones.length / allMilestones.length) * 100) %>%"></div>
  </div>
  <p class="milestone-progress-text"><strong><%= achievedMilestones.length %></strong> of <strong><%= allMilestones.length %></strong> milestones achieved</p>
  <% if (achievedMilestones.length > 0) { %>
  <div class="recent-milestones">
    <% achievedMilestones.sort((a, b) => new Date(b.achieved_at) - new Date(a.achieved_at)).slice(0, 3).forEach(m => { %>
    <div class="milestone-chip achieved">
      <span class="check">&#10003;</span> <%- m.title %>
    </div>
    <% }); %>
  </div>
  <% } %>
</section>
<% } %>

<% if (updates.length > 0) { %>
<section class="section ekg-section">
  <div class="section-header">
    <h2>Journey</h2>
  </div>
  <div class="ekg-container">
    <svg class="ekg-svg" id="ekgChart"></svg>
  </div>
  <div class="ekg-tooltip" id="ekgTooltip">
    <div class="ekg-tooltip-title" id="ekgTooltipTitle"></div>
    <div class="ekg-tooltip-date" id="ekgTooltipDate"></div>
    <div class="ekg-tooltip-excerpt" id="ekgTooltipExcerpt"></div>
  </div>
</section>
<% } %>

<% if (pinned) { %>
<section class="section">
  <div class="pinned-badge">Pinned Update</div>
  <article class="update-card featured">
    <div class="update-meta">
      <span class="mood mood-<%= pinned.mood %>"><%= pinned.mood === 'great' ? 'Great day' : pinned.mood === 'good' ? 'Good day' : 'Tough day' %></span>
      <time><%= new Date(pinned.update_date || pinned.created_at).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></time>
    </div>
    <h2><a href="/update/<%= pinned.id %>"><%= pinned.title %></a></h2>
    <% if (pinned.photo) { %>
    <div class="update-photo"><img src="<%= pinned.photo %>" alt="<%= pinned.title %>" loading="lazy"></div>
    <% } %>
    <div class="update-preview"><%- pinned.content.substring(0, 300).replace(/\n/g, '<br>') %><%= pinned.content.length > 300 ? '...' : '' %></div>
    <a href="/update/<%= pinned.id %>" class="read-more">Read full update</a>
  </article>
</section>
<% } %>

<section class="section">
  <h2 class="section-title">Updates</h2>
  <% if (updates.length === 0) { %>
    <div class="empty-state"><p>No updates yet. Check back soon!</p></div>
  <% } %>
  <div class="updates-list">
    <% updates.forEach(function(update) { %>
      <% if (!pinned || update.id !== pinned.id) { %>
      <article class="update-card">
        <div class="update-meta">
          <span class="mood mood-<%= update.mood %>"><%= update.mood === 'great' ? 'Great day' : update.mood === 'good' ? 'Good day' : 'Tough day' %></span>
          <time><%= new Date(update.update_date || update.created_at).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }) %></time>
        </div>
        <h3><a href="/update/<%= update.id %>"><%= update.title %></a></h3>
        <% if (update.photo) { %>
        <div class="update-photo"><img src="<%= update.photo %>" alt="<%= update.title %>" loading="lazy"></div>
        <% } %>
        <div class="update-preview"><%- update.content.substring(0, 200).replace(/\n/g, '<br>') %><%= update.content.length > 200 ? '...' : '' %></div>
        <a href="/update/<%= update.id %>" class="read-more">Read more</a>
      </article>
      <% } %>
    <% }) %>
  </div>
</section>

<% if (vitals.length >= 3) { %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<script>
  const vitalsData = <%- JSON.stringify(vitals.reverse()) %>;
  const weightData = vitalsData.filter(v => v.weight_grams).map(v => ({
    x: new Date(v.recorded_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
    y: v.weight_grams
  }));

  if (weightData.length >= 3) {
    new Chart(document.getElementById('weightChart'), {
      type: 'line',
      data: {
        labels: weightData.map(d => d.x),
        datasets: [{
          label: 'Weight (g)',
          data: weightData.map(d => d.y),
          borderColor: '#e44b6a',
          backgroundColor: 'rgba(228, 75, 106, 0.1)',
          fill: true,
          tension: 0.3,
          pointBackgroundColor: '#e44b6a',
          pointRadius: 4,
          pointHoverRadius: 6,
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false },
          title: { display: true, text: 'Weight Over Time', font: { size: 14, family: 'Inter' }, color: '#9ca3af' }
        },
        scales: {
          y: { title: { display: true, text: 'Grams', color: '#6b7280' }, beginAtZero: false, ticks: { color: '#6b7280' }, grid: { color: 'rgba(45,50,60,0.5)' } },
          x: { title: { display: true, text: 'Date', color: '#6b7280' }, ticks: { color: '#6b7280' }, grid: { color: 'rgba(45,50,60,0.5)' } }
        }
      }
    });
  }
</script>
<% } %>

<% if (updates.length > 0) { %>
<script>
(function() {
  const allUpdates = <%- JSON.stringify(updates.map(u => ({ id: u.id, title: u.title, sentiment: u.sentiment || 5, content: u.content.substring(0, 120), update_date: u.update_date || u.created_at, mood: u.mood }))) %>;

  // Sort chronologically
  const sorted = allUpdates.slice().sort((a, b) => new Date(a.update_date) - new Date(b.update_date));
  if (sorted.length === 0) return;

  const svg = document.getElementById('ekgChart');
  const tooltip = document.getElementById('ekgTooltip');
  const tooltipTitle = document.getElementById('ekgTooltipTitle');
  const tooltipDate = document.getElementById('ekgTooltipDate');
  const tooltipExcerpt = document.getElementById('ekgTooltipExcerpt');

  const pad = { top: 20, right: 30, bottom: 30, left: 35 };
  const rect = svg.getBoundingClientRect();
  const W = Math.max(rect.width, 400);
  const H = 180;

  svg.setAttribute('viewBox', '0 0 ' + W + ' ' + H);
  svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');

  const chartW = W - pad.left - pad.right;
  const chartH = H - pad.top - pad.bottom;

  // Grid lines
  for (let i = 0; i <= 4; i++) {
    const y = pad.top + (chartH / 4) * i;
    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    line.setAttribute('x1', pad.left);
    line.setAttribute('x2', W - pad.right);
    line.setAttribute('y1', y);
    line.setAttribute('y2', y);
    line.setAttribute('class', 'ekg-grid-line');
    svg.appendChild(line);
  }

  // Y-axis labels
  const yLabels = ['10', '7', '5', '3', '1'];
  yLabels.forEach((label, i) => {
    const y = pad.top + (chartH / 4) * i;
    const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    text.setAttribute('x', pad.left - 8);
    text.setAttribute('y', y + 3);
    text.setAttribute('text-anchor', 'end');
    text.setAttribute('class', 'ekg-label');
    text.textContent = label;
    svg.appendChild(text);
  });

  // Compute points
  const points = sorted.map((u, i) => {
    const x = sorted.length === 1 ? chartW / 2 : (i / (sorted.length - 1)) * chartW;
    const sentiment = Math.max(1, Math.min(10, u.sentiment || 5));
    const y = chartH - ((sentiment - 1) / 9) * chartH;
    return { x: pad.left + x, y: pad.top + y, update: u };
  });

  // Build EKG-style path with sharp peaks
  function buildEkgPath(pts) {
    if (pts.length === 1) return 'M ' + pts[0].x + ' ' + pts[0].y;

    let d = 'M ' + pts[0].x + ' ' + pts[0].y;
    for (let i = 1; i < pts.length; i++) {
      const prev = pts[i - 1];
      const curr = pts[i];
      const midX = (prev.x + curr.x) / 2;

      // Flat segment, then sharp spike to the value - like an EKG
      const flatY = (prev.y + curr.y) / 2;
      const spikeX1 = midX - (curr.x - prev.x) * 0.08;
      const spikeX2 = midX + (curr.x - prev.x) * 0.08;

      d += ' L ' + spikeX1 + ' ' + prev.y;
      d += ' L ' + midX + ' ' + curr.y;
      d += ' L ' + spikeX2 + ' ' + curr.y;
      d += ' L ' + curr.x + ' ' + curr.y;
    }
    return d;
  }

  const pathD = buildEkgPath(points);

  // Glow line
  const glow = document.createElementNS('http://www.w3.org/2000/svg', 'path');
  glow.setAttribute('d', pathD);
  glow.setAttribute('class', 'ekg-glow');
  svg.appendChild(glow);

  // Filled area under the line
  const areaD = pathD + ' L ' + points[points.length - 1].x + ' ' + (H - pad.bottom) + ' L ' + points[0].x + ' ' + (H - pad.bottom) + ' Z';
  const area = document.createElementNS('http://www.w3.org/2000/svg', 'path');
  area.setAttribute('d', areaD);
  area.setAttribute('class', 'ekg-area');
  area.setAttribute('fill', 'url(#ekgGradient)');
  svg.appendChild(area);

  // Gradient definition
  const defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
  const grad = document.createElementNS('http://www.w3.org/2000/svg', 'linearGradient');
  grad.setAttribute('id', 'ekgGradient');
  grad.setAttribute('x1', '0');
  grad.setAttribute('y1', '0');
  grad.setAttribute('x2', '0');
  grad.setAttribute('y2', '1');
  const stop1 = document.createElementNS('http://www.w3.org/2000/svg', 'stop');
  stop1.setAttribute('offset', '0%');
  stop1.setAttribute('stop-color', '#e44b6a');
  const stop2 = document.createElementNS('http://www.w3.org/2000/svg', 'stop');
  stop2.setAttribute('offset', '100%');
  stop2.setAttribute('stop-color', '#e44b6a');
  stop2.setAttribute('stop-opacity', '0');
  grad.appendChild(stop1);
  grad.appendChild(stop2);
  defs.appendChild(grad);
  svg.insertBefore(defs, svg.firstChild);

  // Main line
  const line = document.createElementNS('http://www.w3.org/2000/svg', 'path');
  line.setAttribute('d', pathD);
  line.setAttribute('class', 'ekg-line');
  svg.appendChild(line);

  // Date labels along x axis
  const dateStep = Math.max(1, Math.floor(sorted.length / 5));
  points.forEach((p, i) => {
    if (i % dateStep === 0 || i === points.length - 1) {
      const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      text.setAttribute('x', p.x);
      text.setAttribute('y', H - 6);
      text.setAttribute('text-anchor', 'middle');
      text.setAttribute('class', 'ekg-label');
      text.textContent = new Date(p.update.update_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      svg.appendChild(text);
    }
  });

  // Interactive points
  points.forEach(p => {
    const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    circle.setAttribute('cx', p.x);
    circle.setAttribute('cy', p.y);
    circle.setAttribute('r', 5);
    circle.setAttribute('fill', '#e44b6a');
    circle.setAttribute('stroke', '#0f1117');
    circle.setAttribute('stroke-width', '2');
    circle.setAttribute('class', 'ekg-point');

    circle.addEventListener('mouseenter', function(e) {
      tooltipTitle.textContent = p.update.title;
      tooltipDate.textContent = new Date(p.update.update_date).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
      tooltipExcerpt.textContent = p.update.content.replace(/\n/g, ' ') + (p.update.content.length >= 120 ? '...' : '');
      tooltip.classList.add('visible');
    });

    circle.addEventListener('mousemove', function(e) {
      tooltip.style.left = (e.clientX + 12) + 'px';
      tooltip.style.top = (e.clientY - 10) + 'px';
    });

    circle.addEventListener('mouseleave', function() {
      tooltip.classList.remove('visible');
    });

    circle.addEventListener('click', function() {
      window.location.href = '/update/' + p.update.id;
    });

    svg.appendChild(circle);
  });
})();
</script>
<% } %>

<%- include('partials/footer') %>
