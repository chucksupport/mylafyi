<%- include('partials/head', { pageTitle: 'Milestones' }) %>

<section class="page-header">
  <h1>Milestones</h1>
  <p class="subtitle"><%= settings.baby_name || 'Myla' %>'s journey, one step at a time</p>
</section>

<%
  const categoryLabels = { breathing: 'Respiratory', feeding: 'Gastrointestinal', growth: 'Skeletal Growth', thermoregulation: 'Thermoregulation', firsts: 'Neurological', iv_and_lines: 'IV & Lines' };
  function formatCategory(cat) { return categoryLabels[cat] || cat.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()); }
  const catStats = {};
  Object.keys(milestones).forEach(cat => {
    const items = milestones[cat];
    const achieved = items.filter(m => m.achieved).length;
    catStats[cat] = { total: items.length, achieved, complete: achieved === items.length && items.length > 0, pct: items.length ? Math.round((achieved / items.length) * 100) : 0 };
  });

  const systemCards = [
    { cat: 'firsts',            icon: '🧠', label: 'Neurological',      sub: 'Firsts & Senses' },
    { cat: 'breathing',         icon: '🫁', label: 'Respiratory',        sub: 'Lungs & Airways' },
    { cat: 'feeding',           icon: '🍼', label: 'Gastrointestinal',   sub: 'Feeding & Digestion' },
    { cat: 'thermoregulation',  icon: '🌡️', label: 'Thermoregulation',  sub: 'Body Temperature' },
    { cat: 'growth',            icon: '🦴', label: 'Skeletal Growth',    sub: 'Weight & Development' },
    { cat: 'iv_and_lines',      icon: '💉', label: 'IV & Lines',         sub: 'Vascular Access' },
  ];
%>

<section class="systems-dashboard">
  <div class="systems-grid">
    <% systemCards.forEach(card => {
      const s = catStats[card.cat] || { total: 0, achieved: 0, complete: false, pct: 0 };
      const circumference = 2 * Math.PI * 36;
      const offset = circumference - (s.pct / 100) * circumference;
    %>
    <a href="#cat-<%= card.cat %>" class="system-card <%= s.complete ? 'system-complete' : s.achieved > 0 ? 'system-active' : '' %>">
      <div class="system-ring-wrap">
        <svg class="system-ring" viewBox="0 0 80 80">
          <!-- Track -->
          <circle cx="40" cy="40" r="36" fill="none" stroke="rgba(61,67,80,0.3)" stroke-width="3"/>
          <!-- Progress arc -->
          <circle cx="40" cy="40" r="36" fill="none"
            stroke="<%= s.complete ? '#34d399' : s.achieved > 0 ? 'rgba(52,211,153,0.6)' : 'transparent' %>"
            stroke-width="3" stroke-linecap="round"
            stroke-dasharray="<%= circumference %>" stroke-dashoffset="<%= offset %>"
            transform="rotate(-90 40 40)"
            class="ring-progress"/>
        </svg>
        <span class="system-icon"><%= card.icon %></span>
        <% if (s.complete) { %>
        <span class="system-complete-badge">&#10003;</span>
        <% } %>
      </div>
      <div class="system-info">
        <span class="system-label"><%= card.label %></span>
        <span class="system-sub"><%= card.sub %></span>
        <span class="system-count"><%= s.achieved %><span class="system-count-sep">/</span><%= s.total %></span>
      </div>
      <!-- Mini milestone ticks -->
      <div class="system-ticks">
        <% const items = milestones[card.cat] || []; items.forEach(m => { %>
        <div class="system-tick <%= m.achieved ? 'tick-done' : '' %>" title="<%= m.title %>"></div>
        <% }) %>
      </div>
    </a>
    <% }) %>
  </div>
</section>

<div class="milestones-page">
  <% Object.keys(milestones).forEach(cat => { %>
  <section class="milestone-category" id="cat-<%= cat %>">
    <h2 class="category-title"><%= formatCategory(cat) %></h2>
    <div class="milestone-list">
      <% milestones[cat].forEach(m => { %>
      <div class="milestone-item <%= m.achieved ? 'achieved' : '' %>">
        <div class="milestone-check"><% if (m.achieved) { %>&#10003;<% } %></div>
        <div class="milestone-info">
          <h3><%= m.title %></h3>
          <% if (m.description) { %><p><%= m.description %></p><% } %>
          <% if (m.achieved && m.achieved_at) { %>
          <time class="milestone-date"><%= new Date(m.achieved_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></time>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </section>
  <% }) %>
</div>

<%- include('partials/footer') %>
